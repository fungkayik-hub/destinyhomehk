# ============================================================
# AI 命盘分析 — 二选一（优先 Microsoft Azure OpenAI）
# ============================================================

# 【推荐】Microsoft Azure OpenAI
# Copilot 背后同款 GPT 引擎，经 Microsoft 云端
# 申请：https://portal.azure.com → 创建「Azure OpenAI」资源
# 部署模型（如 gpt-4o-mini）后填入以下变量：
#
AI_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://你的资源名.openai.azure.com
AZURE_OPENAI_API_KEY=你的azure密钥
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# 【备选】OpenAI 直连
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# 注意：Copilot 手机 App / copilot.microsoft.com 无法直接接入网站
# 必须用 Azure OpenAI API 或 OpenAI API

# ============================================================
# SEO / Google 商家 / 本地搜尋
# ============================================================
# 正式網域（轉 DNS 後填；Vercel Production 建議設）
NEXT_PUBLIC_SITE_URL=https://www.destinyhomehk.com

# Google Search Console 驗證碼（search.google.com/search-console）
GOOGLE_SITE_VERIFICATION=你的驗證碼

# Google Business Profile「分享商家」連結 → 網站會顯示「Google 商家」按鈕
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=https://g.page/你的商家連結

# 可選：YouTube 頻道（用於結構化資料 sameAs）
# NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@你的頻道

# Vercel Cron 密鑰（每日 00:01 HKT 自動更新流日；Vercel → Settings → Cron Jobs 會自動帶 Bearer）
# CRON_SECRET=隨機長字串
